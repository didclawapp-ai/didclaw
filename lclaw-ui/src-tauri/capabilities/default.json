{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认权限；生产默认从 http://127.0.0.1:34127 加载时需 remote 以注入 IPC（与 static_server 端口一致）",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:34127/*",
      "http://127.0.0.1:34127/",
      "http://127.0.0.1:34127",
      "http://localhost:5173/*",
      "http://localhost:5173/",
      "http://localhost:5173",
      "http://127.0.0.1:5173/*",
      "http://127.0.0.1:5173/",
      "http://127.0.0.1:5173"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "invoke-all"
  ]
}
