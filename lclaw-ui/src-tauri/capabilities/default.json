{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "生产权限；仅允许本机静态服务端口（与 static_server.rs DEFAULT_BASE_PORT 一致）注入 IPC",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:34127/*",
      "http://127.0.0.1:34127/",
      "http://127.0.0.1:34127"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "invoke-all"
  ]
}
