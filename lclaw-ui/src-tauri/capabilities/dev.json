{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "dev",
  "description": "开发期额外权限；仅在 tauri dev 时通过 tauri.dev.conf.json 引入，生产构建不加载此文件",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://localhost:5173/*",
      "http://localhost:5173/",
      "http://localhost:5173",
      "http://127.0.0.1:5173/*",
      "http://127.0.0.1:5173/",
      "http://127.0.0.1:5173"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "invoke-all"
  ]
}
