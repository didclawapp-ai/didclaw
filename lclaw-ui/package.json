{
  "name": "lclaw-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "vue-tsc -b && vite build",
    "dist:win": "pnpm run build && electron-builder --win",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "vue-tsc -b --noEmit"
  },
  "build": {
    "appId": "com.lclaw.ui",
    "productName": "LCLAW UI",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**/*", "dist-electron/**/*", "package.json"],
    "win": {
      "target": ["nsis"]
    }
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@tanstack/vue-virtual": "^3.13.23",
    "dompurify": "^3.3.3",
    "echarts": "^6.0.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.9.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.5"
  }
}
