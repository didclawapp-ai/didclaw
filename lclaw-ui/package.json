{
  "name": "didclaw",
  "private": true,
  "version": "0.8.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:tauri": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "build": "vue-tsc -b && vite build",
    "build:tauri": "pnpm run build && tauri build --config src-tauri/tauri.build.conf.json",
    "dist:win": "pnpm run build && tauri build --config src-tauri/tauri.build.conf.json",
    "dist:win:tauri": "pnpm run dist:win",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "vue-tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@tanstack/vue-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "dompurify": "^3.3.3",
    "echarts": "^6.0.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.30",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.5"
  }
}
