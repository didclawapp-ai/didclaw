# 复制本文件为 .env.development / .env.production 后按需填写（勿提交含密钥的 .env）
# Electron 正式形态：网关与 openclaw.json 模型在顶栏「本机」配置；纯 Vite（pnpm dev:web）仅用下方变量联调。
#
# OpenClaw Gateway WebSocket URL（开发时与 Vite 不同端口直连）
VITE_GATEWAY_URL=ws://127.0.0.1:18789

# 网关 token（与 openclaw 配置一致；勿提交真实值）
# VITE_GATEWAY_TOKEN=

# 或使用密码（二选一）
# VITE_GATEWAY_PASSWORD=

# Markdown 外链白名单（逗号分隔）。示例：github.com,*.openclaw.ai,https://docs.example.com
# 未配置时仅允许相对链接、mailto/tel、以及 localhost / 127.0.0.1 的 http(s)。设为 * 表示允许任意 http(s)。
# VITE_LINK_ALLOWLIST=

# ClawHub（技能市场）：可选 Registry 与 CLI token，用于搜索/详情/下载限流与配额（与 `clawhub --token` 一致）
VITE_CLAWHUB_REGISTRY=https://clawhub.ai
# VITE_CLAWHUB_TOKEN=clh_your_token_here

# DidClaw 自更新清单端点（不设置则不检查自更新）
# 清单格式：{ "version": "0.6.0", "notes": "...", "date": "2026-03-30",
#             "platforms": { "windows": "https://.../DidClaw_0.6.0_x64-setup.exe" } }
# VITE_DIDCLAW_UPDATE_ENDPOINT=https://example.com/didclaw-update.json
