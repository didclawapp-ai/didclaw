# 复制为 .env.production 后执行 pnpm build，可把网关参数打进前端静态包（会出现在 JS 内，勿用于泄露场景）。
# 桌面版更推荐在顶栏「本机」写入本地库 didclaw.db（网关与 DidClaw KV）及 ~/.openclaw 模型配置，无需重建 exe。

VITE_GATEWAY_URL=ws://127.0.0.1:18789
# VITE_GATEWAY_TOKEN=
# VITE_GATEWAY_PASSWORD=

# ClawHub 技能市场（可选，与 CLI `--token` 一致）
# VITE_CLAWHUB_TOKEN=clh_your_token_here
